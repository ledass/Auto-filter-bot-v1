# ── Required ──────────────────────────────────────────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=123456:your_bot_token_here
DATABASE_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true
ADMINS=123456789 987654321        # space-separated Telegram user IDs
CHANNELS=-100123456789 -100987654  # space-separated channel IDs the bot watches

# ── Optional ──────────────────────────────────────────────────────────────────
DATABASE_NAME=MediaSearchDB
COLLECTION_NAME=Telegram_files
SESSION=MediaSearchBot
MAX_RESULTS=10                     # files per page
CACHE_TIME=300                     # inline cache seconds
USE_CAPTION_FILTER=false           # also search inside file captions

# ── Force-subscribe (optional) ────────────────────────────────────────────────
AUTH_CHANNEL=-100123456789         # users must join this channel first
AUTH_USERS=                        # extra allowed user IDs (space-separated)

# ── Logging channel (optional) ────────────────────────────────────────────────
LOG_CHANNEL=-100123456789          # bot sends startup message here

# ── Userbot – needed for /index command and index.py ─────────────────────────
USERBOT_STRING_SESSION=            # generate with: python generate_session.py

# ── Custom messages (optional) ───────────────────────────────────────────────
# START_MSG=Hi {mention}! Send me a movie name to search.
# FORCE_SUB_MSG=You must join our channel first!
